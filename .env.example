# Qwen Cloud (Alibaba Cloud Model Studio / DashScope, OpenAI-compatible endpoint)
DASHSCOPE_API_KEY=sk-your-key-here
DASHSCOPE_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1

# Set to 1 to replay deterministic fixtures instead of calling the real API.
# Set to 0 in a real deployment so requests actually hit the Qwen Cloud endpoint.
AUTOPILOT_MOCK_LLM=0

# --- Resilience on the external Qwen Cloud call (see docs/DEPLOYMENT.md) ---
# Per-request wall-clock timeout (seconds) on every live LLM call.
# AUTOPILOT_LLM_TIMEOUT_S=30
# Bounded retries (exponential backoff) on transient failures (429/5xx/timeout).
# AUTOPILOT_LLM_MAX_RETRIES=2
# Hard per-run token kill switch: refuse the next LLM call once a run crosses it.
# AUTOPILOT_RUN_TOKEN_CAP=500000

# Optional: override directory for recorded mock fixtures
# AUTOPILOT_FIXTURES_DIR=src/autopilot/llm/fixtures

# Optional: per-model free-tier token budget (LOCAL ESTIMATE ONLY)
# AUTOPILOT_FREE_TIER_TOKENS=1000000

# --- Deploy smoke test (tests/test_deploy_smoke.py; `make smoke-deploy`) ---
# Base URL of the DEPLOYED backend. The smoke test is SKIPPED entirely unless
# this is set, so it never runs during `make test`.
# AUTOPILOT_SMOKE_BASE_URL=http://<ecs-public-ip>:8080
# Set to 1 to also assert the deployed /api/cloud/selfcheck made a REAL Qwen
# Cloud call (ok:true AND mocked:false). Leave unset for a mock-mode deployment.
# AUTOPILOT_SMOKE_REAL_CLOUD=1
