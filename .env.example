# Qwen Cloud (DashScope OpenAI-compatible endpoint)
DASHSCOPE_API_KEY=sk-your-key-here
DASHSCOPE_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1

# Set to 1 to replay deterministic fixtures instead of calling the real API
AUTOPILOT_MOCK_LLM=0

# Optional: override directory for recorded mock fixtures
# AUTOPILOT_FIXTURES_DIR=src/autopilot/llm/fixtures

# Optional: per-model free-tier token budget (LOCAL ESTIMATE ONLY)
# AUTOPILOT_FREE_TIER_TOKENS=1000000
